{
  "cases": [
    {
      "operation": "request_json",
      "request": {
        "method": "GET",
        "path": "/api/v1/settings"
      },
      "server_response": {
        "status": 200,
        "body": {
          "data": {
            "timezone": "UTC"
          }
        }
      },
      "expected_response": {
        "data": {
          "timezone": "UTC"
        },
        "status_code": 200
      }
    },
    {
      "operation": "request_json",
      "request": {
        "method": "GET",
        "path": "/api/v1/tasks"
      },
      "server_response": {
        "status": 200,
        "body": [
          {
            "id": "task-1"
          }
        ]
      },
      "expected_response": {
        "data": [
          {
            "id": "task-1"
          }
        ],
        "status_code": 200
      }
    },
    {
      "operation": "request_json",
      "request": {
        "method": "GET",
        "path": "/api/v1/no-content"
      },
      "server_response": {
        "status": 204,
        "body": null
      },
      "expected_response": {
        "ok": true,
        "status_code": 204
      }
    },
    {
      "operation": "delete_memories",
      "args": {
        "memory_id": "mem-1"
      },
      "expected_request": {
        "body": {
          "memory_id": "mem-1"
        }
      },
      "server_response": {
        "status": 204,
        "body": null
      },
      "expected_response": {
        "ok": true,
        "status_code": 204,
        "deleted": true,
        "mode": "single"
      }
    }
  ]
}
